# Supabase Configuration
VITE_SUPABASE_URL=your_supabase_url
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# Stripe Configuration (Optional - for real payments)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key

# Resend Configuration (Optional - for custom email templates)
RESEND_API_KEY=re_your_resend_api_key

# Note: If Stripe keys are not configured, the app will run in demo mode
# Demo mode simulates purchases without real payment processing